# Configuração Firebase - use UMA das opções abaixo:

# Opção 1: Caminho para arquivo de credenciais (desenvolvimento local)
FIREBASE_CRED_PATH=caminho/para/credenciais.json

# Opção 2: JSON completo das credenciais (produção/Vercel)
# Cole o conteúdo inteiro do arquivo JSON de credenciais aqui
# FIREBASE_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"..."}

# URL do Firebase Realtime Database
DATABASE_URL=https://seu-projeto.firebaseio.com

# Configuração Flask (opcional)
FLASK_DEBUG=false
PORT=5001
